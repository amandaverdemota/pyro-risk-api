API_USERNAME=
API_PASSWORD=

# By default the app runs without credentials, loading cameras from a
# bundled JSON file with anonymized positions. To use the live API instead,
# comment out CAMERAS_FILE below and fill in the upstream credentials.
CAMERAS_FILE=sample_cameras.json

# PYRO_API_HOST=https://alertapi.pyronear.org/
# PYRO_API_USERNAME=
# PYRO_API_PASSWORD=

# Traefik / public-facing deployment
API_DOMAIN=riskapi.pyronear.org
LETSENCRYPT_EMAIL=

# Persistence (sqlite path inside the container; mounted via volume in compose)
DATABASE_URL=sqlite:////app/data/pyro_risk.db

# Daily refresh schedule. All timestamps in this service are UTC.
CAMERAS_REFRESH_CRON_HOUR=2
CAMERAS_REFRESH_CRON_MINUTE=0
CAMERAS_REFRESH_TIMEZONE=UTC
